    "url": "https://github.com/LivTorgEx/ui-kit/issues"
  },
  "author": {
    "name": "LivTorgEx",
    "url": "https://livtorgex.com"
  },
  "keywords": [
    "react",
    "typescript",
    "tailwindcss",
    "design-system",
    "component-library",
    "ui-kit",
    "livtorgex"
